      "step": 4,
      "name": "Amplification Phase",
      "description": "Coordinated reposting and engagement boosting",
      "timeline": "2026-02-16 onwards"
    },
    {
      "@type": "Procedure",
      "step": 5,
      "name": "Adaptation & Refinement",
